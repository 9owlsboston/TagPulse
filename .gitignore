# Bicep build artifacts
deploy/azure/bicep/main.json
# Sprint 25 D1: token-rotation audit log captures last-4-chars + timestamps.
# Local-only; the GHA cron in D2 maintains the canonical log via its run logs.
deploy/azure/.audit/
.secrets/
# draw.io desktop auto-backup files (hidden dot-prefix, e.g. .$filename.drawio.bkp)
docs/assets/.*.bkp

# Seeded by bootstrap-repo.sh — universal baseline.
# Language-specific patterns: prefer `gh repo create --gitignore <Language>`
# at repo creation. Stack snippets exist for the patterns *this toolkit itself*
# generates (e.g. `*.toolkit-new`) and for layouts the toolkit prescribes.

# --- OS noise ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini
ehthumbs.db

# --- Editor / IDE noise ---
*.swp
*.swo
*~
.idea/
*.iml

# VS Code: ignore by default, but allow committed team settings
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# --- Secrets / local env ---
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.p12
*.pfx

# --- Toolkit artifacts (NEVER commit these) ---
# `bootstrap-repo.sh` writes `<file>.toolkit-new` beside conflicting files for
# manual merge. Accidentally committing them is embarrassing — defend against it.
*.toolkit-new

# --- Logs / temp ---
*.log
logs/
tmp/
.tmp/
.cache/
