# TagPulse environment variables
# Copy to .env and fill in real values

# Database
DATABASE_URL=postgresql+asyncpg://tagpulse:secret@localhost:5432/tagpulse

# MQTT Broker
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info
