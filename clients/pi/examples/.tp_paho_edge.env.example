# TagPulse paho-mqtt smoke publisher — config sidecar
#
# Copy this file to `.tp_paho_edge.env` (same directory) and fill in real values.
# `.tp_paho_edge.env` is gitignored. Do NOT commit the file with a real BROKER_PASS.
#
# Search precedence in paho_smoke_publisher.py:
#   1. --env-file PATH
#   2. $TP_PAHO_EDGE_ENV
#   3. ./.tp_paho_edge.env  (next to the script)
#   4. ~/.tp_paho_edge.env
# Real environment variables override values from the file.

# --- Broker (dev cluster) ---
BROKER_HOST=tpdev-mqtt-mwig6fst.centralus.azurecontainer.io
BROKER_PORT=1883
BROKER_USER=tagpulse
# Pull from Key Vault:
#   ../TagPulse/scripts/azd-kv-get.sh dev mqtt-broker-password
BROKER_PASS=

# --- Targets ---
# test-corp tenant on dev
TENANT_ID=11111111-1111-1111-1111-111111111111
# Sim-Reader-03 (swap for your registered device UUID)
DEVICE_ID=1ea3f4e1-a285-42b2-b753-c63ec3819bec
