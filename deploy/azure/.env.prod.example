# deploy/azure/.env.prod.example  →  copy to .env.prod (gitignored)
#
# Customer-facing production. Manual-approval CD only (deploy-azure.yml on v* tags).
# Bootstrap with:  scripts/azd-bootstrap.sh prod
# Load with:       scripts/azd-env-load.sh prod
#
# IMPORTANT:
# - Treat .env.prod like a credential. Store the real file in a password
#   manager (1Password / Bitwarden) when not in active use; do NOT leave it
#   on disk on a shared workstation.
# - Rotate AZURE_JWT_SECRET requires a coordinated rollout (all sessions
#   invalidated). Postgres + MQTT password rotations are fine any time.

# ── Required ─────────────────────────────────────────────────────────────────
AZURE_ENV_NAME=tagpulse-prod
AZURE_LOCATION=southcentralus
AZURE_SUBSCRIPTION_ID=

# ── App-level environment string ─────────────────────────────────────────────
TAGPULSE_ENVIRONMENT=production

# ── Secrets (seeded into Key Vault by Bicep) ─────────────────────────────────
AZURE_POSTGRES_ADMIN_PASSWORD=
AZURE_JWT_SECRET=
AZURE_MQTT_PASSWORD=

# ── Optional naming overrides ────────────────────────────────────────────────
AZURE_RESOURCE_GROUP=tagpulse-prod-rg
AZURE_NAME_PREFIX=tagpulse

# ── Auto-populated by the postprovision hook (do not set by hand) ────────────
# AZURE_ACR_LOGIN_SERVER=
# AZURE_IMAGE_TAG=
