# deploy/azure/.env.dev.example  →  copy to .env.dev (gitignored)
#
# Cloud sandbox: cheapest SKUs, may be torn down nightly. Not customer-facing.
# Bootstrap with:  scripts/azd-bootstrap.sh dev
# Load with:       scripts/azd-env-load.sh dev

# ── Required ─────────────────────────────────────────────────────────────────
AZURE_ENV_NAME=tagpulse-dev
AZURE_LOCATION=southcentralus
AZURE_SUBSCRIPTION_ID=

# ── App-level environment string (read by Settings.environment) ──────────────
# Stays "dev" so strict-mode validators don't trip on dev-shaped secrets.
TAGPULSE_ENVIRONMENT=dev

# ── Secrets (seeded into Key Vault by Bicep) ─────────────────────────────────
# Generated by azd-bootstrap.sh; rotate any time by editing this file + re-running azd-env-load.sh.
AZURE_POSTGRES_ADMIN_PASSWORD=
AZURE_JWT_SECRET=
AZURE_MQTT_PASSWORD=

# ── Optional naming overrides ────────────────────────────────────────────────
AZURE_RESOURCE_GROUP=tagpulse-dev-rg
AZURE_NAME_PREFIX=tpdev

# ── Auto-populated by the postprovision hook (do not set by hand) ────────────
# AZURE_ACR_LOGIN_SERVER=
# AZURE_IMAGE_TAG=
