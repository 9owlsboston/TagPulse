# deploy/azure/.env.example
#
# Copy to deploy/azure/.env (gitignored) and fill in real values, then run:
#
#     scripts/azd-env-load.sh deploy/azure/.env
#
# This loads everything below into the active azd environment via `azd env set`.
# `azd up` / `azd provision` / `azd deploy` will then pick them up automatically.
#
# DO NOT commit the populated .env file. Real secrets belong in a password
# manager or in Key Vault — this file is only a development convenience for
# the first `azd up`.

# ── Required (azd built-ins) ─────────────────────────────────────────────────
AZURE_ENV_NAME=tagpulse-prod
AZURE_LOCATION=southcentralus
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# ── Required (TagPulse secrets, seeded into Key Vault by Bicep) ──────────────
# Generate fresh values with:
#     openssl rand -base64 32   # postgres + mqtt
#     openssl rand -hex 32      # jwt
AZURE_POSTGRES_ADMIN_PASSWORD=
AZURE_JWT_SECRET=
AZURE_MQTT_PASSWORD=

# ── Optional (defaults from main.bicep) ──────────────────────────────────────
# AZURE_RESOURCE_GROUP=tagpulse-rg
# AZURE_NAME_PREFIX=tagpulse

# ── Populated automatically by the postprovision hook ────────────────────────
# Do not set by hand — `azure.yaml` writes these from deployment outputs after
# `azd provision` succeeds. Listed here only for documentation.
# AZURE_ACR_LOGIN_SERVER=<acr-name>.azurecr.io
# AZURE_IMAGE_TAG=<git-short-sha>
