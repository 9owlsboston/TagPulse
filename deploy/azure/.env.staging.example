# deploy/azure/.env.staging.example  →  copy to .env.staging (gitignored)
#
# Pre-prod mirror of prod topology; smaller SKUs OK. Strict-mode validators on.
# Bootstrap with:  scripts/azd-bootstrap.sh staging
# Load with:       scripts/azd-env-load.sh staging

# ── Required ─────────────────────────────────────────────────────────────────
AZURE_ENV_NAME=tagpulse-staging
AZURE_LOCATION=southcentralus
AZURE_SUBSCRIPTION_ID=

# ── App-level environment string ─────────────────────────────────────────────
# "staging" forces strict-mode in Settings (no dev secret fallbacks, no CORS *,
# strict_migration_check forced True). See src/tagpulse/core/config.py.
TAGPULSE_ENVIRONMENT=staging

# ── Secrets (seeded into Key Vault by Bicep) ─────────────────────────────────
AZURE_POSTGRES_ADMIN_PASSWORD=
AZURE_JWT_SECRET=
AZURE_MQTT_PASSWORD=

# ── Optional naming overrides ────────────────────────────────────────────────
AZURE_RESOURCE_GROUP=tagpulse-staging-rg
AZURE_NAME_PREFIX=tpstg

# ── Auto-populated by the postprovision hook (do not set by hand) ────────────
# AZURE_ACR_LOGIN_SERVER=
# AZURE_IMAGE_TAG=
